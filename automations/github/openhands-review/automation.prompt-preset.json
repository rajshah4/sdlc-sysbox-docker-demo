{
  "preset": "prompt",
  "name": "SDLC Demo - GitHub OpenHands Review",
  "prompt_file": "prompt.md",
  "trigger": {
    "type": "event",
    "source": "github",
    "on": ["pull_request.labeled"],
    "filter": "repository.full_name == '${GITHUB_DEMO_REPOSITORY}' && pull_request != null && label.name == 'openhands-review' && !contains(pull_request.labels[].name, 'openhands:done')"
  },
  "repos": [
    {
      "url": "${GITHUB_DEMO_REPO_URL}",
      "provider": "github",
      "ref": "${GITHUB_DEMO_REF}"
    }
  ],
  "timeout": 600,
  "keep_alive": true,
  "model": "Bedrock-Claude-Haiku-4-5"
}
