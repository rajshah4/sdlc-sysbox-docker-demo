{
  "preset": "prompt",
  "name": "SDLC Demo - GitHub OpenHands QA",
  "prompt_file": "prompt.md",
  "trigger": {
    "type": "event",
    "source": "github",
    "on": ["pull_request.labeled", "issues.labeled"],
    "filter": "repository.full_name == '${GITHUB_DEMO_REPOSITORY}' && label.name == 'openhands-qa' && ((pull_request != null && !contains(pull_request.labels[].name, 'openhands:done')) || (issue.pull_request != null && !contains(issue.labels[].name, 'openhands:done')))"
  },
  "repos": [
    {
      "url": "${GITHUB_DEMO_REPO_URL}",
      "provider": "github",
      "ref": "${GITHUB_DEMO_REF}"
    }
  ],
  "timeout": 1800,
  "keep_alive": true,
  "model": "Bedrock-Claude-Sonnet-4-5-fast"
}
