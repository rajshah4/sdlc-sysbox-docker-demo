{
  "preset": "prompt",
  "name": "SDLC Demo - GitHub OpenHands Build",
  "prompt_file": "prompt.md",
  "trigger": {
    "type": "event",
    "source": "github",
    "on": ["issues.labeled"],
    "filter": "repository.full_name == '${GITHUB_DEMO_REPOSITORY}' && issue.pull_request == null && label.name == 'openhands-build' && !contains(issue.labels[].name, 'openhands:in-progress') && !contains(issue.labels[].name, 'openhands:done')"
  },
  "repos": [
    {
      "url": "${GITHUB_DEMO_REPO_URL}",
      "provider": "github",
      "ref": "${GITHUB_DEMO_REF}"
    }
  ],
  "timeout": 1800,
  "keep_alive": true,
  "model": "Bedrock-Claude-Sonnet-4-5"
}
