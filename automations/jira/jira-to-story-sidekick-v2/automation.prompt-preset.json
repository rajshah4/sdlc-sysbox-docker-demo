{
  "name": "Jira Bug to PR - Visible Sidekick V2",
  "preset": "prompt",
  "prompt_file": "prompt.md",
  "trigger": {
    "type": "event",
    "source": "jira-direct",
    "on": "jira:issue_created",
    "filter": "issue.fields.project.key == '${JIRA_DEMO_PROJECT_KEY}' && issue.fields.issuetype.name == 'Task' && contains(issue.fields.labels, 'sidekick-v2')"
  },
  "repos": [
    {
      "url": "${GITHUB_DEMO_REPO_URL}",
      "ref": "${GITHUB_DEMO_REF}"
    }
  ],
  "timeout": 900,
  "keep_alive": true,
  "model": "Bedrock-Claude-Sonnet-4-5-fast"
}
