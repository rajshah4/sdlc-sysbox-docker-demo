{
  "preset": "prompt",
  "name": "SDLC Demo - Replicated Jira Delegated Factory",
  "prompt_file": "prompt.md",
  "trigger": {
    "type": "event",
    "source": "jira-direct",
    "on": "jira:issue_created",
    "filter": "issue.fields.project.key == '${JIRA_DEMO_PROJECT_KEY}' && issue.fields.issuetype.name == 'Task' && !contains(issue.fields.labels, 'openhands-foundry-parent') && !contains(issue.fields.labels, 'foundry-it-demo') && !contains(issue.fields.labels, 'rtl-request')"
  },
  "repos": [
    {
      "url": "${GITHUB_DEMO_REPO_URL}",
      "provider": "github",
      "ref": "${GITHUB_DEMO_REF}"
    }
  ],
  "timeout": 1800,
  "keep_alive": true,
  "model": "Bedrock-Claude-Sonnet-4-5"
}
