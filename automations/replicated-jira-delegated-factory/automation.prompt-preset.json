{
  "preset": "prompt",
  "name": "SDLC Demo - Replicated Jira Delegated Factory",
  "prompt_file": "prompt.md",
  "trigger": {
    "type": "event",
    "source": "jira-direct",
    "on": "jira:issue_created",
    "filter": "issue.fields.project.key == '${JIRA_DEMO_PROJECT_KEY}' && issue.fields.issuetype.name == 'Task'"
  },
  "repos": [
    {
      "url": "${GITHUB_DEMO_REPO_URL}",
      "provider": "github",
      "ref": "${GITHUB_DEMO_REF}"
    }
  ],
  "timeout": 3600,
  "model": "sdlc-coding"
}
